import { Theme } from "theme.slint";

export global ScrubPreviewFmt {
    public pure function pad2(n: int) -> string {
        if (n < 10) { "0" + n } else { "" + n }
    }

    public pure function short_time(secs: float) -> string {
        let t = Math.floor(secs);
        let m = Math.floor(t / 60);
        let s = Math.mod(t, 60);
        m + ":" + pad2(s)
    }
}

export component ProgressBar inherits Rectangle {
    in property <float> current-time: 0;
    in property <float> duration: 0;
    in property <float> ab-loop-a: -1;
    in property <float> ab-loop-b: -1;

    in property <image> sprite-image;
    in property <bool> sprite-ready: false;
    in property <bool> sprite-loading: false;
    in property <float> sprite-interval-sec: 1.0;
    in property <int> sprite-frame-count: 0;
    in property <int> sprite-columns: 10;
    in property <int> sprite-rows: 1;
    in property <int> sprite-thumb-w: 160;
    in property <int> sprite-thumb-h: 90;

    in property <bool> pointer-hidden: false;

    // Fires once per press/release cycle (plain click or drag release) —
    // the authoritative, frame-accurate seek.
    callback clicked-ratio(float);
    // Fires on every drag tick — cheap, no FFI in the callback itself; the
    // Rust side throttles this into a bounded number of fast/approximate
    // seeks per second instead of one per pixel of mouse movement.
    callback scrub-ratio(float);

    height: 20px;
    property <float> ratio: duration > 0 ? max(0.0, min(1.0, current-time / duration)) : 0.0;
    property <bool> ab-active: ab-loop-a >= 0 || ab-loop-b >= 0;
    property <float> hover-ratio: (drag.has-hover || drag.pressed) && self.width > 0px
        ? max(0.0, min(1.0, drag.mouse-x / self.width))
        : ratio;
    property <float> hover-time: hover-ratio * duration;
    property <int> preview-idx: sprite-ready && sprite-interval-sec > 0 && sprite-frame-count > 0
        ? Math.min(sprite-frame-count - 1, Math.max(0, Math.floor(hover-time / sprite-interval-sec)))
        : 0;
    property <int> preview-col: Math.mod(preview-idx, sprite-columns);
    property <int> preview-row: Math.floor(preview-idx / sprite-columns);
    property <float> preview-thumb-time: preview-idx * sprite-interval-sec;
    property <bool> show-scrub-preview: (drag.has-hover || drag.pressed) && duration > 0
        && (sprite-loading || sprite-ready);

    track := Rectangle {
        x: 0;
        y: parent.height / 2 - 2px;
        height: 4px;
        width: 100%;
        background: Theme.surface-3;
        border-radius: 2px;
    }

    if ab-loop-a >= 0 && ab-loop-b >= 0 && duration > 0: Rectangle {
        y: track.y;
        height: track.height;
        x: (ab-loop-a / duration) * track.width;
        width: max(2px, ((ab-loop-b - ab-loop-a) / duration) * track.width);
        background: Theme.accent-soft-2;
        border-radius: 2px;
    }

    Rectangle {
        x: 0;
        y: track.y;
        height: track.height;
        width: root.ratio * track.width;
        background: Theme.accent;
        border-radius: 2px;
    }

    if ab-loop-a >= 0 && duration > 0: Rectangle {
        x: (ab-loop-a / duration) * track.width - 1px;
        y: track.y - 3px;
        width: 2px;
        height: 10px;
        background: Theme.accent;
        opacity: 0.65;
    }

    if ab-loop-b >= 0 && duration > 0: Rectangle {
        x: (ab-loop-b / duration) * track.width - 1px;
        y: track.y - 3px;
        width: 2px;
        height: 10px;
        background: Theme.accent;
        opacity: 0.65;
    }

    thumb := Rectangle {
        x: root.ratio * track.width - self.width / 2;
        y: parent.height / 2 - self.height / 2;
        width: 12px;
        height: 12px;
        border-radius: 6px;
        background: Theme.fg;
        border-width: 2px;
        border-color: Theme.accent;

        if drag.has-hover || drag.pressed: Rectangle {
            x: -4px;
            y: -4px;
            width: parent.width + 8px;
            height: parent.height + 8px;
            border-radius: 10px;
            background: Theme.accent-soft;
        }
    }

    if show-scrub-preview: Rectangle {
        x: drag.mouse-x - preview-w / 2;
        y: -preview-h - 8px;
        width: preview-w;
        height: preview-h;

        property <length> preview-w: sprite-thumb-w * 1px;
        property <length> preview-h: sprite-thumb-h * 1px;

        // Drop shadow
        Rectangle {
            x: 0;
            y: 4px;
            width: 100%;
            height: 100%;
            border-radius: 8px;
            background: #00000073;
        }

        if sprite-loading && !sprite-ready: Rectangle {
            width: 100%;
            height: 100%;
            border-radius: 6px;
            border-width: 2px;
            border-color: #ffffffd9;
            background: #000000;

            Rectangle {
                width: 22px;
                height: 22px;
                border-radius: 11px;
                border-width: 2px;
                border-color: Theme.accent-soft;
                background: transparent;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
            }
        }

        if sprite-ready: Rectangle {
            width: 100%;
            height: 100%;
            clip: true;
            border-radius: 6px;
            border-width: 2px;
            border-color: #ffffffd9;
            background: #000000;

            Image {
                source: sprite-image;
                x: -preview-col * sprite-thumb-w * 1px;
                y: -preview-row * sprite-thumb-h * 1px;
                width: sprite-columns * sprite-thumb-w * 1px;
                height: sprite-rows * sprite-thumb-h * 1px;
            }

            Rectangle {
                x: 4px;
                y: 4px;
                height: 16px;
                width: time-badge.preferred-width + 10px;
                border-radius: 4px;
                background: #06080cd1;
                border-width: 1px;
                border-color: #ffffff33;

                time-badge := Text {
                    x: 5px;
                    y: 2px;
                    text: ScrubPreviewFmt.short_time(preview-thumb-time);
                    color: #f8fafc;
                    font-size: 10px;
                    font-weight: 700;
                }
            }
        }
    }

    drag := TouchArea {
        enabled: !root.pointer-hidden;
        mouse-cursor: root.pointer-hidden ? none : default;
        // `pointer-event`'s `up` kind covers both a plain click (press+release
        // with no movement) and a drag release, so exactly one authoritative
        // seek fires per press/release cycle — replacing the old `clicked`
        // handler, which combined with `moved` firing the same expensive
        // callback on every raw pointer-move during a drag.
        pointer-event(event) => {
            if (event.button == PointerEventButton.left && event.kind == PointerEventKind.up && self.width > 0px) {
                clicked-ratio(max(0.0, min(1.0, self.mouse-x / self.width)));
            }
        }
        moved => {
            if (self.pressed && self.width > 0px) {
                scrub-ratio(max(0.0, min(1.0, self.mouse-x / self.width)));
            }
        }
    }
}
